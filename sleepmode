#!/bin/bash
# Sleep Mode Toggle Script
# Usage: ./sleepmode on | ./sleepmode off

ACTION=$1
CONFIG_FILE="/root/.openclaw/workspace/neko-futures-trader/config.py"

if [ "$ACTION" = "on" ]; then
    echo "🟡 Enabling SLEEP MODE..."
    sed -i 's/SLEEP_MODE = False/SLEEP_MODE = True/' "$CONFIG_FILE"
    echo "✅ Sleep Mode ON - Max 4 positions, Min score 7"
elif [ "$ACTION" = "off" ]; then
    echo "🟢 Disabling SLEEP MODE..."
    sed -i 's/SLEEP_MODE = True/SLEEP_MODE = False/' "$CONFIG_FILE"
    echo "✅ Sleep Mode OFF - Max 8 positions, Min score 6"
else
    echo "Usage: ./sleepmode on | ./sleepmode off"
    exit 1
fi

# Restart scanner to apply changes
systemctl restart neko-scanner
echo "Scanner restarted"
